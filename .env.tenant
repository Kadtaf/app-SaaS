// Sert uniquement à exécuter les migrations dans les bases des tenants. Ne pas utiliser pour exécuter l'application en mode tenant, car la base de données est dynamique et doit être créée avant d'exécuter l'application.
APP_ENV=tenant
APP_DEBUG=0

# La base sera remplacée dynamiquement par le service TenantDatabaseCreator
DATABASE_URL="postgresql://app:app@localhost:5432/%dbName%?serverVersion=16&charset=utf8"